[Unit]
Description=Robot Kiosk Web Browser
After=network-online.target NetworkManager.service
Wants=network-online.target

[Service]
Type=simple
SyslogIdentifier=robot-browser
ExecStart=/usr/lib/robot-browser/robotbrowser.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Run as root (direct framebuffer access)
User=root

# Allow framebuffer and input device access
SupplementaryGroups=video input

[Install]
WantedBy=multi-user.target
